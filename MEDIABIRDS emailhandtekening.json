              "id": "b3db5fa6-6090-4b93-b6f6-bdc7fa613bbf",
              "name": "html",
              "value": "<!doctype html> <html lang=\"nl\"> <head>   <meta charset=\"utf-8\" />   <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />   <title>E-mail signature</title>   <style>     table {       font-family: 'Inter', Arial, sans-serif;       font-size: 12px;       border-collapse: collapse;     }     a, td {       color: #000000;       text-decoration: none;     }   </style> </head>  <body>   <table role=\"presentation\">     <tr>       <td style=\"padding-bottom: 16px;\">         Met vriendelijke groet, Kind Regards<br><br>       </td>     </tr>   </table>    <table role=\"presentation\">     <tr>       <td>         <img src=\"https://mediabirds.nl/wp-content/uploads/2024/01/nielsteunissen.png\"              alt=\"Niels Teunissen, Digital Lead\"><br><br>       </td>     </tr>   </table>    <table role=\"presentation\" style=\"line-height: 20px;\">     <tr>       <td style=\"width: 30px;\">M:</td>       <td>         <a href=\"tel:+31629913888\">+ 31 (6) 299 13 888</a>       </td>     </tr>     <tr>       <td style=\"width: 30px;\">E:</td>       <td>         <a href=\"mailto:niels.teunissen@mediabirds.nl\">niels.teunissen@mediabirds.nl</a>       </td>     </tr>   </table>    <table role=\"presentation\">     <tr>       <td>         <br><br>         <img src=\"https://mediabirds.nl/wp-content/uploads/2024/01/logo.png\"              alt=\"Logo Mediabirds\"><br><br>       </td>     </tr>   </table>    <table role=\"presentation\" style=\"line-height: 20px;\">     <tr>       <td>         <a href=\"https://www.google.com/maps/place/Mediabirds+-+Webdesign+Bureau+Amsterdam/@52.3654317,4.8864403,15z/data=!4m6!3m5!1s0x47c609258afd2ed1:0x8de5dd15b3762d9b!8m2!3d52.3654317!4d4.8864403!16s%2Fg%2F11nmt3gkhw?entry=ttu\">Amsterdam</a>         <span style=\"padding: 0 5px;\">|</span>         <a href=\"https://www.google.com/maps/place/Mediabirds+-+Webdesign+Bureau+Ede/@52.0335891,5.6073683,15z/data=!4m2!3m1!1s0x0:0x3e07a57c6295619?sa=X&ved=2ahUKEwjV6Le7gpmDAxXf4AIHHfXSBQwQ_BJ6BAhLEAA\">Ede</a>         <br><br>       </td>     </tr>   </table>    <table role=\"presentation\" style=\"line-height: 20px;\">     <tr>       <td style=\"width: 30px;\">T:</td>       <td><a href=\"tel:0202445304\">020 244 53 04</a></td>     </tr>     <tr>       <td style=\"width: 30px;\">E:</td>       <td><a href=\"mailto:hello@mediabirds.nl\">hello@mediabirds.nl</a></td>     </tr>     <tr>       <td style=\"width: 30px;\">W:</td>       <td><a href=\"https://www.mediabirds.nl\">www.mediabirds.nl</a></td>     </tr>   </table>    <table role=\"presentation\">     <tr>       <td style=\"padding-right: 5px;\">         <a href=\"https://nl.linkedin.com/company/mediabirds-nl\">           <br>           <img src=\"https://mediabirds.nl/wp-content/uploads/2024/01/linkedin.png\" alt=\"Linkedin\">         </a>       </td>       <td style=\"padding-right: 5px;\">         <a href=\"https://www.instagram.com/mediabirds.nl/\">           <br>           <img src=\"https://mediabirds.nl/wp-content/uploads/2024/01/instagram.png\" alt=\"Instagram\">         </a>       </td>       <td style=\"padding-right: 5px;\">         <a href=\"https://m.facebook.com/mediabirdsnl-104851165087050\">           <br>           <img src=\"https://mediabirds.nl/wp-content/uploads/2024/01/facebook.png\" alt=\"Facebook\">         </a>       </td>     </tr>   </table> </body> </html>",
